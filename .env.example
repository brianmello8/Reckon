# =============================================================================
# Reckon — Environment Variables
# Copy to .env.local and fill in real values. Never commit .env.local.
# =============================================================================

# Database (Supabase / Neon Postgres)
DATABASE_URL=postgresql://user:password@localhost:5432/reckon

# Clerk (authentication)
CLERK_SECRET_KEY=sk_test_xxxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (billing)
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# Anthropic (Admin API — for polling usage, not proxied)
ANTHROPIC_ADMIN_API_KEY=sk-ant-admin-xxxx

# OpenAI (Admin/Usage API)
OPENAI_ADMIN_API_KEY=sk-admin-xxxx

# GitHub App (Copilot billing API)
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Slack (bot + OAuth)
SLACK_CLIENT_ID=xxxx.xxxx
SLACK_CLIENT_SECRET=xxxx
SLACK_SIGNING_SECRET=xxxx

# Linear (issue creation + OAuth)
LINEAR_API_KEY=lin_api_xxxx
LINEAR_OAUTH_CLIENT_ID=xxxx
LINEAR_OAUTH_CLIENT_SECRET=xxxx

# AWS KMS (envelope encryption for provider keys)
AWS_KMS_KEY_ID=arn:aws:kms:us-east-1:123456789:key/xxxx
AWS_ACCESS_KEY_ID=AKIA_xxxx
AWS_SECRET_ACCESS_KEY=xxxx
AWS_REGION=us-east-1

# Resend (transactional email)
RESEND_API_KEY=re_xxxx

# Sentry (error monitoring — optional)
SENTRY_DSN=https://xxxx@sentry.io/xxxx

# Inngest (background jobs)
INNGEST_EVENT_KEY=xxxx
INNGEST_SIGNING_KEY=signkey-xxxx

# Set to "1" to skip env validation (e.g. in Docker builds)
# SKIP_ENV_VALIDATION=1
